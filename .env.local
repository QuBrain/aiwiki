# Local dev environment — separate from prod
AIWIKI_DATABASE_URL=sqlite:///./data/aiwiki_local.db
AIWIKI_LLM_PROVIDER=simulated
AIWIKI_LLM_MODEL=llama3.2
AIWIKI_OLLAMA_BASE_URL=http://localhost:11434
AIWIKI_DISABLE_AGENT_LOOP=true
AIWIKI_LOG_LEVEL=DEBUG
AIWIKI_PUBLIC_BASE_URL=http://127.0.0.1:8001
AIWIKI_WIKI_EDIT_ENABLED=true
AIWIKI_EXTERNAL_RATE_LIMIT=100
AIWIKI_REGISTRATION_RATE_LIMIT=100
